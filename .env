
---------------------------
# 数据库
# 你当前本地 PostgreSQL 用户是 postgres，密码是自己设置的，我这里用123456
# -----------------------------
DATABASE_URL=postgresql+psycopg://postgres:123456@localhost:5432/ecommerce_agent

# -----------------------------
# 当前业务领域包
# -----------------------------
ACTIVE_DOMAIN=robot_vacuum

# -----------------------------
# LLM 配置
# -----------------------------
LLM_ENABLE=true
DASHSCOPE_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-max

LLM_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=1

# -----------------------------
# 订单截图视觉识别
# 上传订单截图后，用视觉模型提取订单号、商品、金额、状态等信息
# -----------------------------
VISION_LLM_ENABLE=true
VISION_LLM_MODEL=qwen-vl-plus

# -----------------------------
# API / 前端
# 如果你是前端直接走本地 Agent 逻辑，可以用 local
# 如果你是 Streamlit 前端调用 FastAPI 后端，建议改成 api
# -----------------------------
FRONTEND_BACKEND_MODE=api
API_BASE_URL=http://127.0.0.1:8001
AGENT_API_BASE_URL=http://127.0.0.1:8001
API_FALLBACK_TO_LOCAL=true
FRONTEND_DEV_MODE=0


EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# -----------------------------
# 人工审核策略
# 金额超过该阈值时触发人工审核
# -----------------------------
HUMAN_REVIEW_AMOUNT_THRESHOLD=1000